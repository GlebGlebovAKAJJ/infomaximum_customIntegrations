            "blocks": [
                {
                    "settings": "{\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Ручной запуск",
                    "use_workspace_connection": false,
                    "guid": "a1",
                    "type": "manual_start",
                    "fields": {
                        "expected_fields": [
                            {
                                "is_array": false,
                                "is_required": true,
                                "rank": 0,
                                "guid": "90f62bf4a33b4c92b2fca7991d18a5d7",
                                "field_type": "text",
                                "field_name": "Почтовый ящик"
                            },
                            {
                                "is_array": false,
                                "is_required": true,
                                "guid": "9448b1557558463691386facf4805325",
                                "rank": 1,
                                "field_type": "text",
                                "field_name": "Тип уведомления"
                            },
                            {
                                "is_array": false,
                                "is_required": true,
                                "guid": "08cf7d7105f1404b8884e17af1934848",
                                "rank": 2,
                                "field_type": "integer",
                                "field_name": "Cтатус"
                            },
                            {
                                "is_array": false,
                                "is_required": true,
                                "rank": 3,
                                "guid": "6980bd6c94bb46f58978e81d926e9181",
                                "field_type": "text",
                                "field_name": "Идентификатор записи"
                            }
                        ]
                    }
                },
                {
                    "settings": "{\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Записываем в `db-170`.`teams_notification_subscriptions`",
                    "use_workspace_connection": true,
                    "guid": "a2",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "UPDATE `db-170`.`teams_notification_subscriptions`\n\nSET\n    is_active       = if(${a6.is_active} = 1, 0, 1),\n    started_at      = if(${a6.is_active} = 0, ${a6.start_time}, null),\n    ended_at        = if(${a6.is_active} = 1, ${a6.start_time}, null),\n    last_change_at  = ${a6.start_time},\n    last_change_by  = ${a6.email}\n    \nWHERE row_id = ${a6.row_id}"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Готовим данные для записи",
                    "use_workspace_connection": true,
                    "guid": "a6",
                    "type": "sql_select_query_workspace",
                    "fields": {
                        "script": "SELECT\n  ${a1.Cтатус} as is_active,\n  ${a1.start_time} as start_time,\n  formatDateTime(parseDateTimeBestEffort(${a1.start_time}), '%d.%m.%Y %H:%i', 'Europe\/Moscow') as now_dt_formatted,\n  generateUUIDv4() as event_uuid,\n  'https:\/\/portal.corp.infomaximum.com\/im\/report\/7231\/publish' as dashboard_url,\n  ${a1.Почтовый ящик} as email,\n  (SELECT first_name FROM employee WHERE email = ${a1.Почтовый ящик}) employee_name,\n  ${a1.Идентификатор записи} as row_id"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Синхронизатор",
                    "use_workspace_connection": false,
                    "guid": "a17",
                    "type": "synchronizer",
                    "fields": {}
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Если была деактивация",
                    "use_workspace_connection": false,
                    "guid": "a31",
                    "type": "filter",
                    "fields": {
                        "conditions": [
                            [
                                {
                                    "condition": "IS_NOT_EMPTY",
                                    "data_field": "${a10.cards_became_inactive}"
                                }
                            ]
                        ]
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Если была активация",
                    "use_workspace_connection": false,
                    "guid": "a32",
                    "type": "filter",
                    "fields": {
                        "conditions": [
                            [
                                {
                                    "condition": "IS_NOT_EMPTY",
                                    "data_field": "${a10.cards_became_active}"
                                }
                            ]
                        ]
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Создание параметров",
                    "use_workspace_connection": true,
                    "guid": "a9",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "work_in_session": true,
                        "script": "SET param_email = ${a1.Почтовый ящик},\n  param_start = ${a1.start_time}\n  -- param_row = ${a1.Идентификатор записи}"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Забираем данные из временной таблицы, готовим к отправке",
                    "use_workspace_connection": true,
                    "guid": "a10",
                    "type": "sql_select_query_workspace",
                    "fields": {
                        "work_in_session": true,
                        "script": "SELECT\n    arrayStringConcat(groupArrayIf(collection.card_name_ru, tt.is_active = 0), ';') as cards_became_inactive,\n    arrayStringConcat(groupArrayIf(collection.card_name_ru, tt.is_active = 1), ';') as cards_became_active,\n    tt.last_change_by as email,\n    emp.first_name as employee_name,\n    tt.last_change_at as start_time,\n    formatDateTime(tt.last_change_at, '%d.%m.%Y %H:%i', 'Europe\/Moscow') as start_time_formatted,\n    'https:\/\/portal.corp.infomaximum.com\/im\/report\/7231\/publish' as dashboard_url\nFROM `db-170`.`teams_notification_subscriptions` as tt\nJOIN `db-170`.`adaptive_cards_collection` collection\n    ON collection.uuid = tt.event_type_id::UUID\nJOIN employee as emp \n    ON emp.email = tt.last_change_by\nWHERE last_change_at = {start: String} AND last_change_by = {email: String} -- tt.row_id = {row: String}\nGROUP BY email, employee_name, start_time"
                    }
                },
                {
                    "settings": "{\"isCIBlock\":true,\"fields\":{}}",
                    "connection_guid": "32f01926-aef4-4003-9001-4c3165c9efbd",
                    "name": "Подписка (глобальная, типовая): активация (Системное)",
                    "use_workspace_connection": false,
                    "guid": "a19",
                    "type": "f3192bc5-ac77-4cf1-8cfa-f83828d05a32.GlobalSubscriptionActivation",
                    "fields": {
                        "change_scope": "types",
                        "change_source": "user",
                        "started_at": "${a10.start_time_formatted}",
                        "employee_name": "${a10.employee_name}",
                        "card_names": "${a10.cards_became_active}",
                        "dashboard_url": "${a10.dashboard_url}",
                        "email": "${a10.email}",
                        "card_uuid": "23c04ff4-221f-40f4-9618-6da1ee1d711e"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Логируем событие в `db-170`.`power_automation_requests_log`",
                    "use_workspace_connection": true,
                    "guid": "a22",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170`.`power_automation_requests_log`\n  (\n      card_uuid,\n      duration_ms,\n      event_uuid,\n      flow_endpoint,\n      message,\n      recipients,\n      send_time,\n      send_uid,\n      status\n  )\nVALUES\n  (\n    ${a25.card_uuid},\n    ${a25.duration_ms},\n    generateUUIDv4(),\n    ${a25.flow_endpoint},\n    ${a25.message},\n    ${a25.recipients},\n    parseDateTime64BestEffort(${a25.send_time}),\n    ${a25.send_uid},\n    ${a25.status}\n  )"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "ГЛУШАКОФФ",
                    "use_workspace_connection": false,
                    "guid": "a23",
                    "type": "filter",
                    "fields": {
                        "conditions": [
                            [
                                {
                                    "condition": "EQUALS",
                                    "data_field": "2",
                                    "value": "1"
                                }
                            ]
                        ]
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":true,\"fields\":{}}",
                    "connection_guid": "32f01926-aef4-4003-9001-4c3165c9efbd",
                    "name": "Подписка (глобальная, типовая): деактивация (Системное)",
                    "use_workspace_connection": false,
                    "guid": "a24",
                    "type": "f3192bc5-ac77-4cf1-8cfa-f83828d05a32.GlobalSubscriptionDeactivation",
                    "fields": {
                        "change_scope": "types",
                        "change_source": "user",
                        "deactivated_at": "${a10.start_time_formatted}",
                        "employee_name": "${a10.employee_name}",
                        "card_names": "${a10.cards_became_inactive}",
                        "dashboard_url": "${a10.dashboard_url}",
                        "email": "${a10.email}",
                        "card_uuid": "22c04ff4-221f-40f4-9618-6da1ee1d711e"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Логируем событие в `db-170`.`power_automation_requests_log`",
                    "use_workspace_connection": true,
                    "guid": "a25",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170`.`power_automation_requests_log`\n  (\n      card_uuid,\n      duration_ms,\n      event_uuid,\n      flow_endpoint,\n      message,\n      recipients,\n      send_time,\n      send_uid,\n      status\n  )\nVALUES\n  (\n    ${a22.card_uuid},\n    ${a22.duration_ms},\n    generateUUIDv4(),\n    ${a22.flow_endpoint},\n    ${a22.message},\n    ${a22.recipients},\n    parseDateTime64BestEffort(${a22.send_time}),\n    ${a22.send_uid},\n    ${a22.status}\n  )"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "ГЛУШАКОФФ",
                    "use_workspace_connection": false,
                    "guid": "a26",
                    "type": "filter",
                    "fields": {
                        "conditions": [
                            [
                                {
                                    "condition": "EQUALS",
                                    "data_field": "2",
                                    "value": "1"
                                }
                            ]
                        ]
                    }
                }
            ],
