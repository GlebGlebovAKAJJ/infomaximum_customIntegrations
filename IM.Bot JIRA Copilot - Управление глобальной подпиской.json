                    "use_workspace_connection": true,
                    "guid": "a12",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170` . `teams_notification_recipients` (is_active, last_change_at, last_change_by, subscribed_at, unsubscribed_at, email_address)\nVALUES (\n  1,\n  ${a1.start_time},\n  ${a1.Почтовый ящик},\n  ${a1.start_time},\n  null,\n  ${a1.Почтовый ящик} \n)"
                    }
