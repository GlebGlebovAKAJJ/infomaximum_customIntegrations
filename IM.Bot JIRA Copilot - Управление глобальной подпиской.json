                    "guid": "a1",
                    "type": "manual_start",
                    "fields": {
                        "expected_fields": [
                            {
                                "is_array": false,
                                "is_required": true,
                                "rank": 0,
                                "guid": "e8d43413944743d5b076f800e2089eec",
                                "field_type": "text",
                                "field_name": "Почтовый ящик"
                            }
                        ]
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Проверяем наличие email в таблице",
                    "use_workspace_connection": true,
                    "guid": "a2",
                    "type": "sql_select_query_workspace",
                    "fields": {
                        "script": "select\n  count() as row,\n  ${a1.start_time} as start_time,\n  formatDateTime(parseDateTimeBestEffort(${a1.start_time}), '%d.%m.%Y %H:%i', 'Europe\/Moscow')as start_time_formatted,\n  'https:\/\/portal.corp.infomaximum.com\/im\/report\/7231\/publish' as dashboard_url,\n  (SELECT first_name FROM employee WHERE email =  ${a1.Почтовый ящик}) as employee_name,\n  any(is_active) as is_active\nfrom `db-170` . `teams_notification_recipients`\nwhere\n  email_address = ${a1.Почтовый ящик}"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "обновление строки в оригинальной таблице `teams_notification_recipients",
                    "use_workspace_connection": true,
                    "guid": "a14",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "UPDATE `db-170` . `teams_notification_recipients`\nSET\n  is_active = if(${a2.is_active} = 0, 1, 0),\n  last_change_at = ${a1.start_time},\n  last_change_by = ${a1.Почтовый ящик},\n  subscribed_at = if(${a2.row} = 1 and ${a2.is_active} = 1, null, ${a2.start_time}),\n  unsubscribed_at = if(${a2.row} = 1 and ${a2.is_active} = 1, ${a1.start_time}, null)\nWHERE\n  email_address = ${a1.Почтовый ящик}"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Логируем событие в `db-170`.`power_automation_requests_log`",
                    "use_workspace_connection": true,
                    "guid": "a30",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170`.`power_automation_requests_log`\n  (\n      card_uuid,\n      duration_ms,\n      event_uuid,\n      flow_endpoint,\n      message,\n      recipients,\n      send_time,\n      send_uid,\n      status\n  )\nVALUES\n  (\n    ${a29.card_uuid},\n    ${a29.duration_ms},\n    generateUUIDv4(),\n    ${a29.flow_endpoint},\n    ${a29.message},\n    ${a29.recipients},\n    ${a29.send_time},\n    ${a29.send_uid},\n    ${a29.status}\n  )"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":true,\"fields\":{}}",
                    "connection_guid": "a0625cee-dca2-4ba4-a2fb-9419dc69cec7",
