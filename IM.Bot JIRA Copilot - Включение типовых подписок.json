{
    "schema_version": 2,
    "scripts": [
        {
            "author": "Козлова Екатерина Сергеевна",
            "blocks": [
                {
                    "settings": "{\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Ручной запуск",
                    "use_workspace_connection": false,
                    "guid": "a1",
                    "type": "manual_start",
                    "fields": {
                        "expected_fields": [
                            {
                                "is_array": false,
                                "is_required": true,
                                "guid": "d6db6dc527bd4f7dbf11eb6cb1956e32",
                                "rank": 0,
                                "field_type": "text",
                                "field_name": "Почтовый ящик"
                            },
                            {
                                "is_array": true,
                                "is_required": true,
                                "rank": 1,
                                "guid": "e10bd0f7690a4b41b46d33393abc39c1",
                                "field_type": "text",
                                "field_name": "Тип уведомления"
                            }
                        ]
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Записываем UUID в переменную ",
                    "use_workspace_connection": true,
                    "guid": "a13",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "work_in_session": true,
                        "script": "SET \n    param_cards = ${a1.Тип уведомления[]},\n  param_email = ${a1.Почтовый ящик}"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Проверка на дубли",
                    "use_workspace_connection": true,
                    "guid": "a20",
                    "type": "sql_select_query_workspace",
                    "fields": {
                        "script": "SELECT\n  ${a1.Почтовый ящик} as email,\n  arrayJoin(${a1.Тип уведомления[]})::UUID as card_uuid,\n  collection.card_name_ru as card_name_ru\nFROM `db-170`.`adaptive_cards_collection` collection\nWHERE \n  card_uuid NOT IN (\n    SELECT \n      event_type_id \n    FROM `db-170`.`teams_notification_subscriptions` \n    WHERE email = ${a1.Почтовый ящик}\n  ) \n  and collection.uuid = card_uuid"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Записываем в `db-170`.`teams_notification_subscriptions`",
                    "use_workspace_connection": true,
                    "guid": "a21",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170`.`teams_notification_subscriptions` \n(\n    email,\n    event_type_id,\n    event_type_name,\n    is_active,\n    started_at,\n    last_change_at,\n    last_change_by\n)\nVALUES \n(\n    ${a20.email},\n    ${a20.card_uuid},\n    ${a20.card_name_ru},\n    1,\n    parseDateTimeBestEffort(${a1.start_time}),\n    parseDateTimeBestEffort(${a1.start_time}),\n    ${a20.email}\n)"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Синхронизатор",
                    "use_workspace_connection": false,
                    "guid": "a22",
                    "type": "synchronizer",
                    "fields": {}
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Готовим данные для отправки уведомления",
                    "use_workspace_connection": true,
                    "guid": "a23",
                    "type": "sql_select_query_workspace",
                    "fields": {
                        "work_in_session": true,
                        "script": "SELECT\n    now() as started_at,\n    formatDateTime(now(), '%d.%m.%Y %H:%i', 'Europe\/Moscow') as started_at_formatted,\n    'https:\/\/portal.corp.infomaximum.com\/im\/report\/7231\/publish' as dashboard_url,\n    generateUUIDv4() as event_uuid,\n    any(subquery.email) as email,\n    any(employee.first_name) as employee_name,\n    arrayStringConcat(groupArray(collection.card_name_ru), ';') as card_names\nFROM (\n    SELECT \n        {email: String} as email,\n        arrayJoin({cards: Array(UUID)}) as card_uuid\n) AS subquery\nJOIN `db-170`.`adaptive_cards_collection` AS collection\n    ON collection.uuid = subquery.card_uuid\nJOIN employee \n    ON employee.email = subquery.email"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":true,\"fields\":{}}",
                    "connection_guid": "32f01926-aef4-4003-9001-4c3165c9efbd",
                    "name": "Подписка (глобальная, типовая): активация (Системное)",
                    "use_workspace_connection": false,
                    "guid": "a24",
                    "type": "f3192bc5-ac77-4cf1-8cfa-f83828d05a32.GlobalSubscriptionActivation",
                    "fields": {
                        "change_scope": "types",
                        "change_source": "user",
                        "started_at": "${a23.started_at_formatted}",
                        "employee_name": "${a23.employee_name}",
                        "card_names": "${a23.card_names}",
                        "dashboard_url": "${a23.dashboard_url}",
                        "email": "${a23.email}",
                        "card_uuid": "23c04ff4-221f-40f4-9618-6da1ee1d711e"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "Логируем событие в `db-170`.`power_automation_requests_log`",
                    "use_workspace_connection": true,
                    "guid": "a26",
                    "type": "sql_update_query_workspace",
                    "fields": {
                        "script": "INSERT INTO `db-170`.`power_automation_requests_log`\n  (\n      card_uuid,\n      duration_ms,\n      event_uuid,\n      flow_endpoint,\n      message,\n      recipients,\n      send_time,\n      send_uid,\n      status\n  )\nVALUES\n  (\n    ${a24.card_uuid},\n    ${a24.duration_ms},\n    generateUUIDv4(),\n    ${a24.flow_endpoint},\n    ${a24.message},\n    ${a24.recipients},\n    parseDateTime64BestEffort(${a24.send_time}),\n    ${a24.send_uid},\n    ${a24.status}\n  )"
                    }
                },
                {
                    "settings": "{\"isTimeoutBlock\":false,\"isCIBlock\":false,\"fields\":{}}",
                    "connection_guid": null,
                    "name": "ГЛУШАКОФФ",
                    "use_workspace_connection": false,
                    "guid": "a27",
                    "type": "filter",
                    "fields": {
                        "conditions": [
                            [
                                {
                                    "condition": "EQUALS",
                                    "data_field": "2",
                                    "value": "1"
                                }
                            ]
                        ]
                    }
                }
            ],
            "name": "IM.Bot JIRA Copilot | Включение типовых подписок",
